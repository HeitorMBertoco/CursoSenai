generator client {
  provider = "prisma-client-js" 
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ProdutoModel {
  id              Int     @id @default(autoincrement())
  nome            String
  habilitado      Boolean @default(true)
  nomearquivofoto String
  descricao       String
  quantidadeAtual Int     @default(0)

  categoria   CategoriaProduto @relation(fields: [categoriaId], references: [id])
  categoriaId Int

  unidadeMedida   UnidadeMedida @relation(fields: [unidadeMedidaId], references: [id])
  unidadeMedidaId Int


  operacaoEstoqueDetalhe OperacaoEstoqueDetalhe?
}

model CategoriaProduto {
  id        Int    @id @default(autoincrement())
  nome      String
  descricao String

  produtos ProdutoModel[]
}

model UnidadeMedida {
  id          Int     @id @default(autoincrement())
  sigla       String
  descricao   String
  fracionavel Boolean @default(false)

  produtos ProdutoModel[]
}

model OperacaoEstoque {
  id           Int      @id @default(autoincrement())
  hora         DateTime @default(now())
  motivo       String
  entradasaida String

  operacaoestoquedetalhes OperacaoEstoqueDetalhe[]
}

model OperacaoEstoqueDetalhe {
  id         Int   @id @default(autoincrement())
  quantidade Int
  precoCusto Float

  operacaoEstoque   OperacaoEstoque @relation(fields: [operacaoEstoqueId], references: [id], onDelete: Cascade)
  operacaoEstoqueId Int


  produto   ProdutoModel @relation(fields: [produtoId], references: [id])
  produtoId Int          @unique
}
